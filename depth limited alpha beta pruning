def heuristic_alpha_beta(
        game,
        depth,
        max_depth,
        alpha,
        beta,
        maximizing):

    result = game.winner()

    if result == 'X':
        return 100

    if result == 'O':
        return -100

    if result == 'Draw':
        return 0

    if depth == max_depth:
        return evaluate(game)

    if maximizing:

        value = -math.inf

        for move in game.available_moves():

            game.make_move(move)

            value = max(
                value,
                heuristic_alpha_beta(
                    game,
                    depth+1,
                    max_depth,
                    alpha,
                    beta,
                    False
                )
            )

            game.undo_move(move)

            alpha = max(alpha, value)

            if alpha >= beta:
                break

        return value

    else:

        value = math.inf

        for move in game.available_moves():

            game.make_move(move)

            value = min(
                value,
                heuristic_alpha_beta(
                    game,
                    depth+1,
                    max_depth,
                    alpha,
                    beta,
                    True
                )
            )

            game.undo_move(move)

            beta = min(beta, value)

            if beta <= alpha:
                break

        return value
